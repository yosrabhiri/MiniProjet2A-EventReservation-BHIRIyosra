{% extends 'base.html.twig' %}

{% block title %}Liste des événements{% endblock %}

{% block body %}
 <section class="search-panel">
    <form method="get" action="{{ path('app_event') }}" class="search-bar">
        <div class="row g-3 align-items-center">
            <div class="col-lg-3 search-segment">
                <label for="location" class="search-label">Lieu</label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    class="form-control border-0 shadow-none"
                    placeholder="Où se déroule l'événement ?"
                    value="{{ app.request.get('location') }}"
                >
            </div>

            <div class="col-lg-3 search-segment">
                <label for="date" class="search-label">Date</label>
                <input
                    type="date"
                    id="date"
                    name="date"
                    class="form-control border-0 shadow-none"
                    value="{{ app.request.get('date') }}"
                >
            </div>

            <div class="col-lg-3 search-segment">
                <label for="seats" class="search-label">Places minimum</label>
                <input
                    type="number"
                    id="seats"
                    name="seats"
                    class="form-control border-0 shadow-none"
                    placeholder="Ex: 10"
                    min="1"
                    value="{{ app.request.get('seats') }}"
                >
            </div>

            <div class="col-lg-3">
                <button type="submit" class="search-btn">🔎 Rechercher</button>
            </div>
        </div>
    </form>

    <div class="mt-3">
        <a href="{{ path('app_event') }}" class="chip">Réinitialiser</a>
        <a href="{{ path('app_event', { location: 'Tunis' }) }}" class="chip">Tunis</a>
        <a href="{{ path('app_event', { location: 'Sfax' }) }}" class="chip">Sfax</a>
        <a href="{{ path('app_event', { location: 'Sousse' }) }}" class="chip">Sousse</a>
    </div>
</section>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title mb-0">Événements populaires</h2>
        <div class="text-muted">1 / 2</div>
    </div>

    {% if events is empty %}
        <div class="alert alert-light border rounded-4">
            Aucun événement disponible pour le moment.
        </div>
    {% else %}
        <div class="row g-4">
            {% for event in events %}
                <div class="col-md-6 col-xl-4">
                    <div class="event-card">
                        <div class="card-image-wrapper">
                            {% if event.image %}
                                <img src="{{ event.image}}" alt="{{ event.title }}" class="event-image">
                            {% else %}
                                <img src="https://via.placeholder.com/800x500?text=Event" alt="Image par défaut" class="event-image">
                            {% endif %}

                            <div class="badge-top">Populaire</div>
                        </div>

                        <div class="event-card-body">
                            <div class="event-title">{{ event.title }}</div>

                            <div class="event-location">📍 {{ event.location }}</div>

                            <div class="event-meta">
    👥 {{ event.seats }} participants
    &nbsp;&nbsp;
    📅 {% if event.date %}{{ event.date|date("d/m/Y H:i") }}{% endif %}
</div>

                            <div class="event-desc">

                                    {{ event.description }}

                            </div>

                            <div class="event-footer d-flex justify-content-between align-items-end">
                                <div>
                                    <div class="price-label">Réservation à partir de</div>
                                    <div class="price-value">120 DT</div>
                                </div>

                                <a href="{{ path('event_reserve', { id: event.id }) }}" class="btn btn-outline-dark rounded-pill px-4">
                                    Voir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
