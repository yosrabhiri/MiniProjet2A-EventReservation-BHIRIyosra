{% extends 'base.html.twig' %}

{% block title %}Liste des événements{% endblock %}



{% block body %}
<section class="search-panel">
    <form id="search-form" class="search-bar">
        <div class="row g-3 align-items-center">
            <div class="col-lg-3 search-segment">
                <label for="location" class="search-label">Lieu</label>
                <input
                    type="text"
                    id="location"
                    name="location"
                    class="form-control border-0 shadow-none"
                    placeholder="Où se déroule l'événement ?"
                >
            </div>

            <div class="col-lg-3 search-segment">
                <label for="date" class="search-label">Date</label>
                <input
                    type="date"
                    id="date"
                    name="date"
                    class="form-control border-0 shadow-none"
                >
            </div>

            <div class="col-lg-3 search-segment">
                <label for="seats" class="search-label">Places minimum</label>
                <input
                    type="number"
                    id="seats"
                    name="seats"
                    class="form-control border-0 shadow-none"
                    placeholder="Ex: 10"
                    min="1"
                >
            </div>

            <div class="col-lg-3">
                <button type="submit" class="search-btn">🔎 Rechercher</button>
            </div>
        </div>
    </form>

    <div class="mt-3 d-flex gap-2 flex-wrap">
        <button type="button" class="chip" onclick="resetFilters()">Réinitialiser</button>
        <button type="button" class="chip" onclick="quickFilter('Tunis')">Tunis</button>
        <button type="button" class="chip" onclick="quickFilter('Sfax')">Sfax</button>
        <button type="button" class="chip" onclick="quickFilter('Sousse')">Sousse</button>
        <button type="button" class="chip" onclick="logout()">Logout</button>
    </div>
</section>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">Événements populaires</h2>
    <div class="text-muted" id="events-count">0 événement(s)</div>
</div>

<div id="error-box" class="alert alert-danger" style="display:none;"></div>
<div id="loading-box" class="alert alert-light border rounded-4" style="display:none;">Chargement...</div>

<div id="events-container" class="row g-4"></div>
<script src="/js/auth.js"></script>
<script>
if (!getAccessToken()) {
    window.location.href = '/login';
}

document.addEventListener('DOMContentLoaded', function () {
    document.getElementById('search-form').addEventListener('submit', function (e) {
        e.preventDefault();
        loadEvents();
    });

    loadEvents();
});

function logout() {
    clearTokens();
    window.location.href = '/login';
}

function quickFilter(city) {
    document.getElementById('location').value = city;
    loadEvents();
}

function resetFilters() {
    document.getElementById('location').value = '';
    document.getElementById('date').value = '';
    document.getElementById('seats').value = '';
    loadEvents();
}

async function loadEvents() {
    const errorBox = document.getElementById('error-box');
    const loadingBox = document.getElementById('loading-box');
    const container = document.getElementById('events-container');
    const countBox = document.getElementById('events-count');

    errorBox.style.display = 'none';
    errorBox.textContent = '';
    loadingBox.style.display = 'block';
    container.innerHTML = '';

    const location = document.getElementById('location').value.trim();
    const date = document.getElementById('date').value;
    const seats = document.getElementById('seats').value;

    const params = new URLSearchParams();

    if (location) params.append('location', location);
    if (date) params.append('date', date);
    if (seats) params.append('seats', seats);

    try {
        const response = await apiFetch('/api/events?' + params.toString(), {
            method: 'GET'
        });

        if (response.status === 401) {
            clearTokens();
            window.location.href = '/login';
            return;
        }

        const events = await response.json();

        loadingBox.style.display = 'none';
        countBox.textContent = (Array.isArray(events) ? events.length : 0) + ' événement(s)';

        if (!Array.isArray(events) || events.length === 0) {
            container.innerHTML = `
                <div class="col-12">
                    <div class="alert alert-light border rounded-4">
                        Aucun événement disponible pour le moment.
                    </div>
                </div>
            `;
            return;
        }

        events.forEach(event => {
            const image = event.image
                ? event.image
                : 'https://via.placeholder.com/800x500?text=Event';

            const eventDate = event.date ? formatDate(event.date) : '';

            container.innerHTML += `
                <div class="col-md-6 col-xl-4">
                    <div class="event-card">
                        <div class="card-image-wrapper">
                            <img src="${image}" alt="${escapeHtml(event.title)}" class="event-image">
                            <div class="badge-top">Populaire</div>
                        </div>

                        <div class="event-card-body">
                            <div class="event-title">${escapeHtml(event.title)}</div>

                            <div class="event-location">📍 ${escapeHtml(event.location ?? '')}</div>

                            <div class="event-meta">
                                👥 ${event.seats ?? 0} restants
                                &nbsp;&nbsp;
                                📅 ${eventDate}
                            </div>

                            <div class="event-desc">
                                ${escapeHtml(event.description ?? '')}
                            </div>

                            <div class="event-footer d-flex justify-content-between align-items-end">
                                <div>
                                    <div class="price-label">Réservation à partir de</div>
                                    <div class="price-value">120 DT</div>
                                </div>

                                <a href="/events/${event.id}/reserve" class="btn btn-outline-dark rounded-pill px-4">
                                    Réserver
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        });
    } catch (error) {
        loadingBox.style.display = 'none';
        errorBox.textContent = 'Erreur lors du chargement des événements.';
        errorBox.style.display = 'block';
    }
}

function formatDate(dateString) {
    const date = new Date(dateString);

    if (isNaN(date.getTime())) {
        return dateString;
    }

    return date.toLocaleString('fr-FR');
}

function escapeHtml(value) {
    if (value === null || value === undefined) return '';

    return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}
</script>
{% endblock %}
