{% extends 'base.html.twig' %}

{% block title %}Liste des événements{% endblock %}

{% block body %}
    <section class="search-panel">
        <div class="search-bar">
            <div class="row g-3 align-items-center">
                <div class="col-lg-3 search-segment">
                    <div class="search-label">Location</div>
                    <div class="search-value">Où se déroule l'événement ?</div>
                </div>

                <div class="col-lg-3 search-segment">
                    <div class="search-label">Date</div>
                    <div class="search-value">Choisir une date</div>
                </div>

                <div class="col-lg-3 search-segment">
                    <div class="search-label">Participants</div>
                    <div class="search-value">Nombre de personnes</div>
                </div>

                <div class="col-lg-3">
                    <button class="search-btn">🔎 Rechercher</button>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <span class="me-2 text-muted">Recherches populaires :</span>
            <a href="#" class="chip">Tunis</a>
            <a href="#" class="chip">Sfax</a>
            <a href="#" class="chip">Sousse</a>
            <a href="#" class="chip">Nabeul</a>
        </div>
    </section>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title mb-0">Événements populaires</h2>
        <div class="text-muted">1 / 2</div>
    </div>

    {% if events is empty %}
        <div class="alert alert-light border rounded-4">
            Aucun événement disponible pour le moment.
        </div>
    {% else %}
        <div class="row g-4">
            {% for event in events %}
                <div class="col-md-6 col-xl-4">
                    <div class="event-card">
                        <div class="card-image-wrapper">
                            {% if event.image %}
                                <img src="{{ event.image}}" alt="{{ event.title }}" class="event-image">
                            {% else %}
                                <img src="https://via.placeholder.com/800x500?text=Event" alt="Image par défaut" class="event-image">
                            {% endif %}

                            <div class="badge-top">Populaire</div>
                        </div>

                        <div class="event-card-body">
                            <div class="event-title">{{ event.title }}</div>

                            <div class="event-location">📍 {{ event.location }}</div>

                            <div class="event-meta">
    👥 {{ event.seats }} participants
    &nbsp;&nbsp;
    📅 {% if event.date %}{{ event.date|date("d/m/Y H:i") }}{% endif %}
</div>

                            <div class="event-desc">

                                    {{ event.description }}

                            </div>

                            <div class="event-footer d-flex justify-content-between align-items-end">
                                <div>
                                    <div class="price-label">Réservation à partir de</div>
                                    <div class="price-value">120 DT</div>
                                </div>

                                <a href="#" class="btn btn-outline-dark rounded-pill px-4">
                                    Voir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
